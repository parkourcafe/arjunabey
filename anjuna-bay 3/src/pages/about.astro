---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { canonicalFor } from '../lib/seo';

const page = await getEntry('pages', 'about');
const { Content } = await page.render();
const d = page.data;
---

<BaseLayout
  title={d.seo?.title ?? 'About | Anjuna Bay'}
  description={d.seo?.description ?? 'The story of Anjuna Bay.'}
  canonicalUrl={canonicalFor('/about')}
  transparentHeader={true}
>
  {
    d.heroImage && (
      <div class="relative h-[50vh] min-h-[320px] overflow-hidden">
        <img src={d.heroImage.src} alt="Anjuna Bay estate" class="absolute inset-0 h-full w-full object-cover" />
        <div class="absolute inset-0 bg-gradient-to-t from-ink/70 via-ink/10 to-transparent" aria-hidden="true" />
        <div class="container-content relative z-10 flex h-full flex-col justify-end pb-14 text-paper">
          <h1 class="max-w-lg font-serif text-h1 font-medium">{d.title}</h1>
        </div>
      </div>
    )
  }
  <div class="container-content section">
    <div class="prose-anjuna max-w-prose">
      <Content />
    </div>
  </div>
</BaseLayout>
