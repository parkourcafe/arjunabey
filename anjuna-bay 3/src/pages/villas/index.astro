---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import VillaCard from '../../components/VillaCard.astro';
import { itemList, canonicalFor } from '../../lib/seo';

// Includes off-plan villas — VillaCard shows a "Coming soon" badge and the
// page still exists (see villas/[slug].astro), so the estate's pipeline is
// visible rather than hidden. Only 'live' villas are ever bookable
// (CLAUDE.md rule 7 lives in RateBlock/StickyBookingBar, not in this filter).
const villas = (await getCollection('villas')).sort((a, b) => a.data.order - b.data.order);
const liveCount = villas.filter((v) => v.data.status === 'live').length;

// Filter option lists are derived from the actual content, never hardcoded —
// an option only appears if a villa exists that matches it, so the filter
// can never produce a guaranteed-empty result on load.
const bedroomOptions = [...new Set(villas.map((v) => v.data.bedrooms))].sort((a, b) => a - b);
const VIEW_KEYWORDS = ['ocean', 'cliff', 'garden'];
const viewOptions = VIEW_KEYWORDS.filter((kw) =>
  villas.some((v) => v.data.view.toLowerCase().includes(kw))
);

const canonicalUrl = canonicalFor('/villas');
const jsonLd = itemList(
  villas.map((v) => ({ name: v.data.landmarkName, url: canonicalFor(`/villas/${v.slug}`) }))
);
---

<BaseLayout
  title="The Villas — Cliffside Pool Villas at Thomas Beach | Anjuna Bay"
  description="Cliffside pool villas above Thomas Beach, Uluwatu — one page per villa, with real walk-times, rates and honest notes on what's nearby."
  canonicalUrl={canonicalUrl}
  jsonLd={jsonLd}
>
  <div class="container-content pb-section pt-32 md:pt-40">
    <SectionHeading
      eyebrow="The villas"
      heading="Cliffside pool villas, a short walk from Thomas Beach"
    />
    <p class="mt-5 max-w-2xl text-ink">
      Each villa has its own page, its own honest walk-time to the beach, and its own rate — no
      unit codes, no guessing. {liveCount < villas.length
        ? "One is still being built; we say so rather than hide it."
        : 'Everything below is confirmed and bookable.'}
    </p>

    {
      villas.length > 0 && (
        <div class="mt-10 flex flex-wrap items-end gap-6 border-b border-hairline pb-8">
          <div>
            <label for="filter-bedrooms" class="eyebrow mb-2 block">
              Bedrooms
            </label>
            <select
              id="filter-bedrooms"
              class="border border-hairline bg-paper px-3 py-2 text-sm text-ink focus:border-ocean focus:outline-none"
            >
              <option value="any">Any bedrooms</option>
              {bedroomOptions.map((n) => (
                <option value={n}>
                  {n} bedroom{n > 1 ? 's' : ''}
                </option>
              ))}
            </select>
          </div>
          <div>
            <label for="filter-view" class="eyebrow mb-2 block">
              View
            </label>
            <select
              id="filter-view"
              class="border border-hairline bg-paper px-3 py-2 text-sm text-ink focus:border-ocean focus:outline-none"
            >
              <option value="any">Any view</option>
              {viewOptions.map((v) => (
                <option value={v}>{v[0].toUpperCase() + v.slice(1)}</option>
              ))}
            </select>
          </div>
          <p class="ml-auto text-sm text-muted" data-filter-count />
        </div>
      )
    }

    <div id="villa-grid" class="mt-8 grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {villas.map((villa) => <VillaCard villa={villa} />)}
    </div>

    {
      villas.length === 0 && (
        <p class="mt-12 text-muted">
          No villas are confirmed live yet — check back shortly, or{' '}
          <a href="/contact">message us</a> directly.
        </p>
      )
    }
    <p class="mt-12 hidden text-muted" data-filter-empty>
      No villas match those filters right now — <a href="/contact">message us</a> and we'll check
      what's coming.
    </p>
  </div>
</BaseLayout>

<script>
  // Client-side filter — no page reload, no framework (villas.length is small
  // and already fully rendered; this just toggles visibility). Consistent
  // with the site's zero-client-JS-unless-needed budget (CLAUDE.md).
  const bedroomsSelect = document.getElementById('filter-bedrooms') as HTMLSelectElement | null;
  const viewSelect = document.getElementById('filter-view') as HTMLSelectElement | null;
  const grid = document.getElementById('villa-grid');
  const emptyMsg = document.querySelector('[data-filter-empty]');
  const countLabel = document.querySelector('[data-filter-count]');
  const cards = grid ? Array.from(grid.querySelectorAll<HTMLElement>('a[data-bedrooms]')) : [];

  function applyFilters() {
    const bedrooms = bedroomsSelect?.value ?? 'any';
    const view = viewSelect?.value ?? 'any';
    let visible = 0;
    for (const card of cards) {
      const matchesBedrooms = bedrooms === 'any' || card.dataset.bedrooms === bedrooms;
      const matchesView = view === 'any' || (card.dataset.view ?? '').includes(view);
      const show = matchesBedrooms && matchesView;
      card.style.display = show ? '' : 'none';
      if (show) visible += 1;
    }
    emptyMsg?.classList.toggle('hidden', visible !== 0);
    if (countLabel) countLabel.textContent = `${visible} villa${visible === 1 ? '' : 's'}`;
  }

  bedroomsSelect?.addEventListener('change', applyFilters);
  viewSelect?.addEventListener('change', applyFilters);
  applyFilters();
</script>
