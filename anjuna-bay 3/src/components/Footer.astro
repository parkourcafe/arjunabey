---
/**
 * Footer — rich, Aman-style footer (docs/BUILD.md §3): page index, villa
 * index by bedroom count, contact + WhatsApp, book-direct block, newsletter,
 * guest social (never @anjunabay — that account sells real estate, CLAUDE.md
 * rule 5), utility links, and exactly one restrained investment-enquiries
 * link. Villa index is derived live from the content collection so it can
 * never drift out of sync with what's actually bookable.
 */
import { getCollection } from 'astro:content';
import WhatsAppButton from './WhatsAppButton.astro';

// Includes off-plan villas (marked "coming soon" below) so the footer index
// never contradicts the villas listing page — see villas/index.astro.
const allVillas = await getCollection('villas');
const byBedrooms = new Map<number, typeof allVillas>();
for (const villa of allVillas) {
  const list = byBedrooms.get(villa.data.bedrooms) ?? [];
  list.push(villa);
  byBedrooms.set(villa.data.bedrooms, list);
}
const bedroomGroups = [...byBedrooms.entries()].sort(([a], [b]) => a - b);

const year = new Date().getUTCFullYear();
---

<footer class="border-t border-hairline bg-paper">
  <div class="container-content grid grid-cols-1 gap-12 py-section md:grid-cols-4 md:gap-8">
    <div>
      <p class="eyebrow mb-4">Explore</p>
      <ul class="space-y-2 text-sm">
        <li><a href="/villas">The Villas</a></li>
        <li><a href="/experiences">Experiences</a></li>
        <li><a href="/the-place">The Place</a></li>
        <li><a href="/offers">Offers</a></li>
        <li><a href="/journal">Journal</a></li>
        <li><a href="/about">About</a></li>
      </ul>

      {
        bedroomGroups.length > 0 && (
          <>
            <p class="eyebrow mb-4 mt-8">Villas by size</p>
            <ul class="space-y-2 text-sm">
              {bedroomGroups.map(([bedrooms, villas]) => (
                <li>
                  {bedrooms}-Bedroom —{' '}
                  {villas.map((v, i) => (
                    <>
                      <a href={`/villas/${v.slug}`}>
                        {v.data.landmarkName}
                        {v.data.status === 'off-plan' ? ' (coming soon)' : ''}
                      </a>
                      {i < villas.length - 1 ? ', ' : ''}
                    </>
                  ))}
                </li>
              ))}
            </ul>
          </>
        )
      }
    </div>

    <div>
      <p class="eyebrow mb-4">Contact</p>
      <address class="text-sm not-italic leading-relaxed text-ink">
        Thomas Beach<br />
        Uluwatu, Pecatu<br />
        Bali, Indonesia
      </address>
      <p class="mt-4 text-sm text-muted">We usually reply within minutes.</p>
      <div class="mt-4">
        <WhatsAppButton variant="button" />
      </div>
      <p class="mt-4 text-sm">
        <a href="/contact">Enquire by email →</a>
      </p>
    </div>

    <div>
      <p class="eyebrow mb-4">Book direct</p>
      <p class="text-sm leading-relaxed text-ink">
        Reserve with us directly for our best available rate and a complimentary airport transfer.
      </p>
      <a href="/offers" class="mt-4 inline-block text-sm underline">See the offer →</a>

      <p class="eyebrow mb-3 mt-8">The Journal</p>
      <form class="flex flex-col gap-2" data-newsletter-form>
        <label for="footer-email" class="text-sm text-muted">
          Occasional notes from the estate — no spam.
        </label>
        <div class="flex gap-2">
          <input
            type="email"
            id="footer-email"
            name="email"
            required
            placeholder="you@example.com"
            class="w-full border border-hairline bg-sand px-3 py-2 text-sm text-ink placeholder:text-muted focus:border-ocean focus:outline-none"
          />
          <button type="submit" class="btn-secondary shrink-0 !px-4">Subscribe</button>
        </div>
        <p class="text-xs text-muted" data-newsletter-status></p>
      </form>
    </div>

    <div>
      <p class="eyebrow mb-4">Follow</p>
      <ul class="space-y-2 text-sm">
        {/* Guest brand handles only — never @anjunabay (real estate). TODO: confirm final handles. */}
        <li><a href="https://instagram.com/" target="_blank" rel="noopener noreferrer">Instagram</a></li>
        <li><a href="https://tiktok.com/" target="_blank" rel="noopener noreferrer">TikTok</a></li>
      </ul>
      <p class="eyebrow mb-4 mt-8">Policies</p>
      <ul class="space-y-2 text-sm">
        <li><a href="/privacy">Privacy Notice</a></li>
        <li><a href="/terms">Terms</a></li>
        <li><a href="/accessibility">Accessibility</a></li>
        <li>
          <button type="button" class="underline" onclick="window.__anjunaOpenConsent && window.__anjunaOpenConsent()">
            Cookie Preferences
          </button>
        </li>
      </ul>
    </div>
  </div>

  <div class="border-t border-hairline">
    <div class="container-content flex flex-col items-start justify-between gap-2 py-6 text-xs text-muted md:flex-row md:items-center">
      <p>&copy; {year} Anjuna Bay. Independent villa operation.</p>
      <p>
        Property and investment enquiries →
        <a href="/contact?type=investment" class="underline">contact us</a>
      </p>
    </div>
  </div>
</footer>

<script>
  const form = document.querySelector('[data-newsletter-form]');
  const status = document.querySelector('[data-newsletter-status]');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    // TODO(newsletter-provider): wire to the chosen double-opt-in provider
    // (docs/BUILD.md §14 open dependencies). Placeholder acknowledgement only.
    if (status) status.textContent = "Thanks — check your inbox to confirm.";
    (form as HTMLFormElement).reset();
  });
</script>
