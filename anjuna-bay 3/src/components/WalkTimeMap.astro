---
/**
 * WalkTimeMap — labelled walk-time rows (location/walk-times carry 12/100 of
 * the booking decision, docs/BUILD.md §3). A static map image slot is left
 * for when a real map/embed is wired in; the rows are the load-bearing part.
 */
import { formatWalkTimes } from '../lib/walktimes';

export interface Props {
  walkTimes: Record<string, number>;
}

const { walkTimes } = Astro.props;
const rows = formatWalkTimes(walkTimes);
---

{
  rows.length > 0 && (
    <div class="border border-hairline bg-paper p-6">
      <p class="eyebrow mb-4">Getting around</p>
      <ul class="space-y-3">
        {rows.map((row) => (
          <li class="flex items-center justify-between border-b border-hairline pb-3 text-sm last:border-b-0 last:pb-0">
            <span class="text-ink">{row.label}</span>
            <span class="text-muted">{row.minutes} min walk</span>
          </li>
        ))}
      </ul>
    </div>
  )
}
