---
/**
 * WhatsAppButton — the always-reachable secondary CTA (CLAUDE.md rule 3).
 * Renders nothing (not even a broken link) if no number is configured yet —
 * silence over a dead button, matching the guesty.ts fallback contract.
 */
import { whatsappLink } from '../lib/whatsapp';

export interface Props {
  villa?: string;
  variant?: 'icon' | 'button' | 'ghost-on-dark';
  class?: string;
  /** Override the visible label (e.g. "Register interest" for off-plan villas). */
  label?: string;
}

const { villa, variant = 'button', class: className = '', label } = Astro.props;
const href = whatsappLink({ villa });
---

{
  href && variant === 'icon' && (
    <a
      href={href}
      target="_blank"
      rel="noopener noreferrer"
      class={`inline-flex h-10 w-10 items-center justify-center rounded-full border border-ink/15 text-ink transition-colors duration-400 ease-elegant hover:border-ocean hover:text-ocean ${className}`}
      aria-label="Message us on WhatsApp"
      data-track="whatsapp_click"
      data-villa={villa ?? ''}
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.46 1.32 4.96L2.05 22l5.25-1.38a9.9 9.9 0 0 0 4.74 1.21h.01c5.46 0 9.9-4.45 9.9-9.91 0-2.65-1.03-5.14-2.9-7.01A9.87 9.87 0 0 0 12.04 2Zm0 18.13h-.01a8.2 8.2 0 0 1-4.19-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.24 8.24 0 0 1-1.26-4.39c0-4.55 3.7-8.25 8.26-8.25 2.2 0 4.27.86 5.83 2.42a8.19 8.19 0 0 1 2.42 5.84c0 4.55-3.71 8.24-8.26 8.24Zm4.52-6.17c-.25-.12-1.47-.72-1.69-.81-.23-.08-.4-.12-.56.13-.17.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.02-.38.11-.51.11-.11.25-.29.37-.43.12-.15.16-.25.25-.41.08-.17.04-.31-.02-.44-.06-.12-.56-1.35-.77-1.85-.2-.48-.41-.42-.56-.43h-.48c-.17 0-.44.06-.67.31-.23.25-.87.85-.87 2.08 0 1.22.89 2.4 1.01 2.57.12.17 1.75 2.67 4.25 3.74.59.26 1.06.41 1.42.52.6.19 1.14.16 1.57.1.48-.07 1.47-.6 1.68-1.18.21-.58.21-1.07.14-1.18-.06-.1-.23-.16-.48-.28Z" />
      </svg>
    </a>
  )
}

{
  href && variant === 'button' && (
    <a
      href={href}
      target="_blank"
      rel="noopener noreferrer"
      class={`btn-secondary ${className}`}
      data-track="whatsapp_click"
      data-villa={villa ?? ''}
    >
      {label ?? 'Message us on WhatsApp'}
    </a>
  )
}

{
  href && variant === 'ghost-on-dark' && (
    <a
      href={href}
      target="_blank"
      rel="noopener noreferrer"
      class={`btn-ghost-on-dark ${className}`}
      data-track="whatsapp_click"
      data-villa={villa ?? ''}
    >
      WhatsApp us
    </a>
  )
}
