---
/**
 * VillaCard — collection-grid card. Order mirrors decision weights (docs/
 * BUILD.md §9.2/§9.3): image first, landmark name + walk-time + price, never
 * a unit code (CLAUDE.md rule 1).
 */
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import { formatWalkTimes } from '../lib/walktimes';

export interface Props {
  villa: CollectionEntry<'villas'>;
}

const { villa } = Astro.props;
const d = villa.data;
const offPlan = d.status === 'off-plan';
const walk = formatWalkTimes(d.walkTimes)[0];
const priceLabel = offPlan
  ? 'Coming soon'
  : d.ratePublic
    ? `from $${d.ratePublic} / night`
    : 'Enquire for rates';
---

<a
  href={`/villas/${villa.slug}`}
  data-bedrooms={d.bedrooms}
  data-view={d.view.toLowerCase()}
  class="group fade-in-up block overflow-hidden bg-paper transition-shadow duration-400 ease-elegant hover:shadow-subtle"
>
  <div class="relative overflow-hidden">
    <Image
      src={d.heroImage}
      alt={`${d.landmarkName} — ${d.bedrooms}-bedroom cliffside pool villa`}
      widths={[400, 800]}
      sizes="(min-width: 768px) 33vw, 100vw"
      class="aspect-[4/3] w-full object-cover transition-transform duration-600 ease-elegant group-hover:scale-[1.03]"
    />
    {offPlan && (
      <span class="absolute left-3 top-3 bg-ink px-3 py-1.5 text-xs font-medium tracking-wide text-paper">
        Coming soon
      </span>
    )}
  </div>
  <div class="p-5">
    <div class="flex items-baseline justify-between gap-3">
      <h3 class="font-serif text-2xl text-ink">{d.landmarkName}</h3>
      {d.rating && (
        <span class="shrink-0 text-xs text-muted">{d.rating.toFixed(2)}★{d.reviewCount ? ` (${d.reviewCount})` : ''}</span>
      )}
    </div>
    <p class="mt-1 text-sm text-muted">
      {d.bedrooms}-Bedroom Pool Villa{walk ? ` · ${walk.minutes}-min walk to ${walk.label}` : ''}
    </p>
    <p class="mt-3 text-sm text-ink">{priceLabel}</p>
  </div>
</a>
