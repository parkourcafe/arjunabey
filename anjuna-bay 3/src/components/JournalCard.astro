---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';

export interface Props {
  post: CollectionEntry<'journal'>;
}

const { post } = Astro.props;
const d = post.data;
const dateLabel = d.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
---

<a href={`/journal/${post.slug}`} class="group block">
  <div class="overflow-hidden">
    <Image
      src={d.heroImage}
      alt={d.title}
      widths={[500, 900]}
      sizes="(min-width: 768px) 33vw, 100vw"
      class="aspect-[3/2] w-full object-cover transition-transform duration-600 ease-elegant group-hover:scale-[1.03]"
    />
  </div>
  <p class="eyebrow mt-4">{d.category} · {dateLabel}</p>
  <h3 class="mt-2 font-serif text-xl text-ink">{d.title}</h3>
  <p class="mt-1 text-sm text-muted">{d.excerpt}</p>
</a>
