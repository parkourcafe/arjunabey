---
/**
 * BaseLayout — the shell every page renders through: <html>, global styles,
 * Header, page content, Footer, CookieConsent. Pages pass SEO props straight
 * through to SeoHead (docs/BUILD.md §9).
 */
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SeoHead from '../components/SeoHead.astro';
import CookieConsent from '../components/CookieConsent.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  canonicalUrl: string;
  ogImage?: string;
  noindex?: boolean;
  jsonLd?: object | object[];
  transparentHeader?: boolean;
}

const {
  title,
  description,
  canonicalUrl,
  ogImage,
  noindex = false,
  jsonLd,
  transparentHeader = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#f3eee7" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Real, self-hosted file (SIL OFL) — see src/styles/tokens.css for why
         only Fraunces is preloaded here and not Inter. -->
    <link
      rel="preload"
      href="/fonts/fraunces-latin-600-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <SeoHead
      title={title}
      description={description}
      canonicalUrl={canonicalUrl}
      ogImage={ogImage}
      noindex={noindex}
      jsonLd={jsonLd}
    />
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:bg-ocean focus:px-4 focus:py-2 focus:text-paper">
      Skip to content
    </a>
    <Header transparent={transparentHeader} />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <CookieConsent />
    <script>
      // Reveal-on-scroll for elements marked .fade-in-up (global.css). A tiny
      // vanilla IntersectionObserver — no framework/island needed, keeps
      // content-page JS near zero (docs/BUILD.md §5 performance budget).
      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              io.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.15 }
      );
      document.querySelectorAll('.fade-in-up').forEach((el) => io.observe(el));
    </script>
  </body>
</html>
